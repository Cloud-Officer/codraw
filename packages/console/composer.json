{
    "name": "codraw/console",
    "description": "This component allow to command execution in the database.",
    "license": "MIT",
    "type": "symfony-bundle",
    "keywords": [
        "draw",
        "console"
    ],
    "require": {
        "doctrine/dbal": "^4.4",
        "codraw/core": "^0.39",
        "psr/log": "^3",
        "ramsey/uuid": "^4.2",
        "sensiolabs/ansi-to-html": "^1.2",
        "symfony/event-dispatcher": "^6.4.0",
        "symfony/console": "^6.4.0"
    },
    "require-dev": {
        "doctrine/orm": "^3.6",
        "codraw/dependency-injection": "^0.39",
        "codraw/tester": "^0.39",
        "phpunit/phpunit": "^12.5",
        "symfony/cache": "^6.4.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Draw\\Component\\Console\\": ""
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "0.38-dev"
        }
    },
    "replace": {
        "draw/console": "self.version"
    }
}
